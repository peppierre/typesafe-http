{
  "name": "@peppierre/typesafe-http",
  "author": "PePPierre <peppierre@gmail.com>",
  "description": "Type-safe HTTP client libraries for Angular using various runtime type checking libraries",
  "keywords": [
    "angular",
    "http",
    "typescript"
  ],
  "scripts": {
    "ng": "ng",
    "build": "npm run build:lib",
    "build:lib": "npm run build:lib:iots && npm run build:lib:zod",
    "build:lib:iots": "node ../scripts/sync-iots-version.js && ng build typesafe-http-iots",
    "build:lib:zod": "node ../scripts/sync-zod-version.js && ng build typesafe-http-zod",
    "lint": "npm run lint:lib",
    "lint:lib": "npm run lint:lib:iots && npm run lint:lib:zod",
    "lint:lib:iots": "ng lint typesafe-http-iots",
    "lint:lib:zod": "ng lint typesafe-http-zod",
    "test": "npm run test:single",
    "test:single": "jest --coverage",
    "test:watch": "jest --coverage --watch",
    "publish:iots": "npm publish ./dist/typesafe-http-iots --access public",
    "publish:zod": "npm publish ./dist/typesafe-http-zod --access public"
  },
  "dependencies": {
    "@angular/animations": "~18.0.0",
    "@angular/common": "~18.0.0",
    "@angular/compiler": "~18.0.0",
    "@angular/core": "~18.0.0",
    "@angular/forms": "~18.0.0",
    "@angular/platform-browser": "~18.0.0",
    "@angular/platform-browser-dynamic": "~18.0.0",
    "@angular/router": "~18.0.0",
    "fp-ts": "^2.16.10",
    "io-ts": "^2.2.22",
    "rxjs": "^7.4.0",
    "tslib": "^2.3.0",
    "zod": "^4.1.3",
    "zone.js": "~0.14.3"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "~18.0.0",
    "@angular/cli": "~18.0.0",
    "@angular/compiler-cli": "~18.0.0",
    "@types/jest": "^30.0.0",
    "angular-eslint": "18.0.0",
    "eslint": "^9.3.0",
    "jest": "^29.7.0",
    "jest-preset-angular": "^14.1.0",
    "ng-packagr": "^18.2.0",
    "typescript": "~5.4.2",
    "typescript-eslint": "8.34.1"
  },
  "peerDependencies": {
    "fp-ts": "^2.16.10",
    "io-ts": "^2.2.22",
    "zod": "^4.1.3"
  },
  "sideEffects": false,
  "jest": {
    "preset": "jest-preset-angular",
    "setupFilesAfterEnv": [
      "<rootDir>/setup.jest.ts"
    ],
    "testPathIgnorePatterns": [
      "<rootDir>/node_modules/",
      "<rootDir>/dist/"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!(.*\\.mjs$|@angular|rxjs|zone\\.js))"
    ],
    "modulePaths": [
      "<rootDir>/projects/typesafe-http-iots/src/",
      "<rootDir>/projects/typesafe-http-zod/src/"
    ],
    "moduleNameMapper": {
      "typesafe-http-iots": "<rootDir>/projects/typesafe-http-iots/src/$1",
      "typesafe-http-zod": "<rootDir>/projects/typesafe-http-zod/src/$1"
    },
    "moduleDirectories": [
      "node_modules",
      "projects/typesafe-http-iots/src",
      "projects/typesafe-http-zod/src"
    ],
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "roots": [
      "projects/typesafe-http-iots",
      "projects/typesafe-http-zod"
    ],
    "testRegex": ".spec.ts$"
  }
}
